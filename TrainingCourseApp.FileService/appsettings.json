{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Settings": {
    "MessageBroker": "SQS",
    "S3Hosting": "Minio"
  },
  "LocalStack": {
    "UseLocalStack": true,
    "Session": {
      "RegionName": "eu-central-1",
      "AwsAccessKeyId": "test",
      "AwsAccessKey": "test"
    },
    "Config": {
      "LocalStackHost": "localhost",
      "EdgePort": 4566,
      "UseSsl": false,
      "UseLegacyPorts": false
    }
  }
}
